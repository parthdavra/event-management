# ── Database ──────────────────────────────────────────────────────────────────
# Plain password (used by the postgres Docker service)
POSTGRES_PASSWORD=your-db-password

# Local dev connection (host = localhost)
# Special chars must be percent-encoded: @ → %40, # → %23
DATABASE_URL=postgresql://postgres:your-db-password@localhost:5432/event_mgmt

# Docker connection (host = 'db' service name) — used by docker-compose backend
DATABASE_URL_DOCKER=postgresql://postgres:your-db-password@db:5432/event_mgmt

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# ── Azure OpenAI ──────────────────────────────────────────────────────────────
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-02-01
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-ada-002

# ── ChromaDB ──────────────────────────────────────────────────────────────────
# Local dev (no Docker ChromaDB): persist to disk
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_USE_HTTP=false

# Docker: connect to chromadb service via HTTP (set CHROMA_USE_HTTP=true)
CHROMA_HOST=chromadb
CHROMA_PORT=8000

# ── Venue APIs ────────────────────────────────────────────────────────────────
# Geoapify — get a free key at https://myprojects.geoapify.com
GEOAPIFY_API_KEY=

# Foursquare Places API
FOURSQUARE_API_KEY=

# ── MCP-Tools server ──────────────────────────────────────────────────────────
# URL of the running FastMCP SSE server
MCP_SERVER_URL=http://localhost:9000
# Project token — must match a value in EM_ALLOWED_CALLER_IDS on the MCP server
MCP_CALLER_ID=evmgmt-parth-2026

# ── Frontend ──────────────────────────────────────────────────────────────────
# URL the Streamlit frontend uses to reach the FastAPI backend
BACKEND_URL=http://localhost:8000
