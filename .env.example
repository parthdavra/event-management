# ── Frontend ──────────────────────────────────────────────────────────────────
# URL the Streamlit frontend uses to reach the FastAPI backend
BACKEND_URL=http://localhost:8000

# ── AWS identity (bootstrap only — everything else lives in Secrets Manager) ──
# The backend fetches DB URL, JWT key, Azure OpenAI, OpenSearch creds, venue API
# keys, MCP caller ID, and Langfuse keys from AWS Secrets Manager at startup —
# see infra/secrets-manager.yml for the secret shell, and populate real values
# with `aws secretsmanager put-secret-value` (never commit them to a file).
# These 5 values are the only ones that stay as plain env vars: they're what
# the app uses to reach Secrets Manager in the first place.
AWS_SECRETS_MANAGER_SECRET_NAME=dstrmaysam-evmgmt-secrets
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_REGION=eu-west-2

# The secret (AWS_SECRETS_MANAGER_SECRET_NAME above) must contain this JSON shape:
# {
#   "database_url": "postgresql://user:pass@your-rds-endpoint.rds.amazonaws.com:5432/event_mgmt",
#   "secret_key": "<python -c \"import secrets; print(secrets.token_hex(32))\">",
#   "azure_openai_api_key": "",
#   "azure_openai_endpoint": "https://your-resource.openai.azure.com/",
#   "azure_openai_api_version": "2024-02-01",
#   "azure_openai_deployment": "gpt-4o",
#   "azure_openai_embedding_deployment": "text-embedding-ada-002",
#   "opensearch_host": "search-xxxx.eu-west-2.es.amazonaws.com",
#   "opensearch_port": 443,
#   "opensearch_username": "",
#   "opensearch_password": "",
#   "opensearch_index_name": "event_management_vectors",
#   "geoapify_api_key": "",
#   "foursquare_api_key": "",
#   "mcp_server_url": "http://localhost:9000",
#   "mcp_caller_id": "evmgmt-parth-2026",
#   "langfuse_secret_key": "",
#   "langfuse_public_key": "",
#   "langfuse_base_url": "https://cloud.langfuse.com"
# }
