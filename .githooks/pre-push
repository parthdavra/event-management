#!/bin/sh
# Runs the backend unit test suite before allowing a push.
# Uses the already-built backend image with the current working tree mounted in,
# so it doesn't need a rebuild or any real DB/AWS credentials to run.
#
# Activate once per clone with:
#   git config core.hooksPath .githooks

echo "Running backend unit tests before push..."

REPO_ROOT=$(git rev-parse --show-toplevel)

docker run --rm \
  -v "${REPO_ROOT}/backend://app" \
  -w //app \
  event-management-backend:latest \
  python -m pytest tests/ -q

status=$?

if [ $status -ne 0 ]; then
    echo ""
    echo "Unit tests failed — push aborted."
    echo "Fix the failing tests, or run 'git push --no-verify' to bypass (not recommended)."
    exit 1
fi

echo "Unit tests passed."
exit 0
