# Database — PostgreSQL (special chars in password are percent-encoded: @ → %40, # → %23)
DATABASE_URL=postgresql://postgres:P%40rth%23123@localhost:5432/event_mgmt

# Azure OpenAI
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-02-01
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-ada-002

# ChromaDB vector store path
CHROMA_PERSIST_DIR=./chroma_db

# Venue API keys (optional — OpenStreetMap/Overpass is always free and needs no key)
FOURSQUARE_API_KEY=your-foursquare-api-key
YELP_API_KEY=your-yelp-bearer-token
